struct HttpResponse {
    pub status: i32,
    pub body: str,
}

struct Error {
    pub message: str,
}

impl Error {
    fn new(msg: str) -> Self {
        Error { message: msg }
    }
}

trait Ord {
    fn cmp(self, other: Self) -> Ordering;
}

enum Ordering {
    Less,
    Equal,
    Greater,
}

trait Clone {
    fn clone(self) -> Self;
}

trait Default {
    fn default() -> Self;
}

struct Box<T> {
    pub value: T,
}
