	$(MAKE) $(MAKESILENT) -f CMakeFiles/nova-lib.dir/build.make CMakeFiles/nova-lib.dir/src/utils/SourceLocation.cpp.i
.PHONY : src/utils/SourceLocation.cpp.i

src/utils/SourceLocation.s: src/utils/SourceLocation.cpp.s
.PHONY : src/utils/SourceLocation.s

# target to generate assembly for a file
src/utils/SourceLocation.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/nova-lib.dir/build.make CMakeFiles/nova-lib.dir/src/utils/SourceLocation.cpp.s
.PHONY : src/utils/SourceLocation.cpp.s

